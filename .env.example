# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/transporti?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Required for encrypted carrier documents and profile photos
DOCUMENTS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# CORS
# Use * during local development, or a comma-separated allowlist for deployed clients
ALLOWED_ORIGINS="*"

# AWS (used for SNS SMS in production; defaults to local credentials in development)
# AWS_REGION_NAME="eu-west-1"   # Optional — falls back to ~/.aws/config region
# SEND_REAL_SMS=true             # Set to true to send real SMS locally (uses your AWS credentials)
