// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum ShipmentStatus {
  PENDING          // En attente (shipment created)
  REQUESTED        // Demandé (carrier applied)
  CONFIRMED        // Confirmé (sender accepted carrier)
  HANDOVER_PENDING // En attente de remise (carrier at pickup, waiting for sender confirmation)
  IN_TRANSIT       // En transit (delivery in progress)
  DELIVERED        // Livré (completed)
  CANCELLED        // Annulé (cancelled)
}

enum NotificationType {
  CARRIER_REQUEST       // Carrier requested shipment
  SHIPMENT_INVITATION   // Sender invited carrier
  REQUEST_ACCEPTED      // Sender accepted carrier
  REQUEST_REJECTED      // Sender rejected carrier
  COUNTER_OFFER         // Sender sent counter-offer
  COUNTER_ACCEPTED      // Carrier accepted counter-offer
  HANDOVER_REQUESTED    // Carrier arrived, asking sender to confirm handover
  HANDOVER_CONFIRMED    // Sender confirmed handover to carrier
  SHIPMENT_IN_TRANSIT   // Shipment started delivery
  SHIPMENT_DELIVERED    // Shipment delivered
}

// Sender model
model Sender {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  firstName   String
  lastName    String
  phone       String
  dateOfBirth String?   // JJ/MM/AAAA stored as-is
  
  // Profile photo (AES-256-CBC encrypted base64)
  profilePhoto String?

  // Rating fields (computed/cached)
  averageRating Float? @default(0)
  totalReviews  Int    @default(0)

  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Push notification token (Expo push token)
  pushToken String?

  // Phone OTP verification
  phoneVerified    Boolean   @default(false)
  otpCode          String?   // bcrypt-hashed 6-digit code
  otpExpiry        DateTime?

  // Email verification
  emailVerified    Boolean   @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  shipments     Shipment[]
  notifications Notification[]
  feedbackEntries ShipmentFeedback[]
  
  @@map("senders")
}

// Carrier model
model Carrier {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  firstName String
  lastName  String
  phone     String
  
  // Carrier-specific fields
  gouvernerat  String?
  license      String?
  matricule    String?
  vehicleType  String?   // VAN, TRUCK, SEMI_TRAILER, DELIVERY_VAN
  vehicleSize  String?   // S, M, L, XL (taille du véhicule)
  dateOfBirth  String?   // JJ/MM/AAAA stored as-is
  verified     Boolean @default(false)

  // Profile photo (AES-256-CBC encrypted base64)
  profilePhoto String?

  // Documents (AES-256-CBC encrypted base64 images)
  cinDoc       String?   // Encrypted CIN photo
  permisDoc    String?   // Encrypted Permis de conduire photo
  docsUploadedAt DateTime? // When docs were last uploaded
  
  // Rating fields (computed/cached)
  averageRating Float? @default(0)
  totalReviews  Int    @default(0)
  
  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Push notification token (Expo push token)
  pushToken String?

  // Phone OTP verification
  phoneVerified    Boolean   @default(false)
  otpCode          String?   // bcrypt-hashed 6-digit code
  otpExpiry        DateTime?

  // Email verification
  emailVerified    Boolean   @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  shipments          Shipment[]
  requestedShipments Shipment[]     @relation("RequestedShipments")
  notifications      Notification[]
  feedbackEntries    ShipmentFeedback[]
  applications       ShipmentApplication[]
  
  @@map("carriers")
}

// Shipment model (created by senders)
model Shipment {
  id          String         @id @default(uuid())
  refNumber   String         @unique // EXP-2938
  from        String
  to          String
  itemName    String?
  pickupDate  String?
  packageFormat String?
  pickupCity  String?
  deliveryCity String?
  cargo       String?
  price       Float?
  budget      Float?
  status      ShipmentStatus @default(PENDING)
  description String?
  
  // Sender relation
  senderId    String
  sender      Sender         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Carrier relation (optional - assigned later)
  carrierId   String?
  carrier     Carrier?       @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  
  // Requested carrier (carrier who expressed interest)
  requestedCarrierId String?
  requestedCarrier   Carrier?       @relation("RequestedShipments", fields: [requestedCarrierId], references: [id], onDelete: SetNull)

  // Sender / recipient contact (when not the logged-in user)
  senderName           String?
  senderPhone          String?
  pickupInstructions   String?
  recipientName        String?
  recipientPhone       String?
  deliveryInstructions String?

  // Helper (porteur) requested at pickup/delivery
  helperCount          Int     @default(0)  // 0=none, 1=1 person (+15 DT), 2=2 people (+30 DT) — pickup side
  deliveryHelperCount  Int     @default(0)  // 0=none, 1=1 person (+15 DT), 2=2 people (+30 DT) — delivery side

  // Meeting point preference
  pickupMeetingPoint   String  @default("vehicle")  // "vehicle" | "home"
  deliveryMeetingPoint String  @default("vehicle")  // "vehicle" | "home"

  // Package photos (base64-encoded images uploaded by the sender)
  packagePhotos        String[]

  // One-time delivery confirmation code (generated when shipment becomes IN_TRANSIT)
  deliveryCode       String?
  
  // Feedback relation (optional - one record per shipment, one entry per party)
  feedback ShipmentFeedback?

  // Carrier applications (TC-106: carrier-proposed pricing)
  applications ShipmentApplication[]
  
  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@map("shipments")
}

// Notification model
model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  
  // Sender relation (optional - if notification is for sender)
  senderId  String?
  sender    Sender?          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Carrier relation (optional - if notification is for carrier)
  carrierId String?
  carrier   Carrier?         @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  
  // Shipment relation (optional - what the notification is about)
  shipmentId String?
  
  // Additional data (JSON)
  data      Json?
  
  // Timestamps
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@map("notifications")
  @@index([senderId, read])
  @@index([carrierId, read])
}

// Shipment feedback model
model ShipmentFeedback {
  id      String  @id @default(uuid())

  // Shipment / parties
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  senderId   String
  sender     Sender   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  carrierId  String
  carrier    Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  // Sender evaluates carrier
  senderToCarrierRating      Int?
  senderToCarrierComment     String?
  senderToCarrierSubmittedAt DateTime?

  // Carrier evaluates sender
  carrierToSenderRating      Int?
  carrierToSenderComment     String?
  carrierToSenderSubmittedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shipment_feedback")
  @@index([senderId])
  @@index([carrierId])
}

// Enum for carrier application status (TC-106)
enum ApplicationStatus {
  PENDING
  COUNTER_OFFERED
  ACCEPTED
  REJECTED
}

// Carrier application for a shipment, with proposed price (TC-106)
model ShipmentApplication {
  id            String            @id @default(uuid())
  shipmentId    String
  shipment      Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrierId     String
  carrier       Carrier           @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  proposedPrice Float
  counterPrice  Float?
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([shipmentId, carrierId])
  @@map("shipment_applications")
}
